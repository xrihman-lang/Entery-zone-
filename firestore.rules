rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // High performance auth checks
    function isOwner() {
      return request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    function isCreatingOwn() {
      return request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Entries collection
    match /entries/{entryId} {
      allow read, delete: if isOwner();
      allow create: if isCreatingOwn();
      allow update: if isOwner() && isCreatingOwn();
    }

    // Invoices collection
    match /invoices/{invoiceId} {
      // List/Query requires ownership
      allow list: if isOwner();
      // Allow unrestricted get by ID to support shared view URLs
      allow get: if true;
      allow create: if isCreatingOwn();
      allow update: if isOwner() && isCreatingOwn();
      allow delete: if isOwner();
    }

    // Stock collection
    match /stock/{itemId} {
      allow read, delete: if isOwner();
      allow create: if isCreatingOwn();
      allow update: if isOwner() && isCreatingOwn();
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'xrihman@gmail.com' || request.auth.token.email == 'mohdalikhan990x@gmail.com');
    }

    // Ledger Tabs collection
    match /ledger_tabs/{tabId} {
      allow read, delete: if isOwner();
      allow create: if isCreatingOwn();
      allow update: if isOwner() && isCreatingOwn();
    }

    match /support_tickets/{ticketId} {
      allow create: if true; // Any user can submit feedback
      allow read: if request.auth != null && (request.auth.token.email == 'xrihman@gmail.com' || request.auth.token.email == 'mohdalikhan990x@gmail.com');
      allow update, delete: if false; 
    }
  }
}
