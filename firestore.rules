rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidEntry(data) {
      return data.id is string &&
             data.date is string &&
             data.customerName is string &&
             data.customerName.size() <= 100 &&
             data.type in ['S', 'O', 'V', 'K', 'D', 'SU', 'OM'] &&
             data.totalAmount is number &&
             data.receivedAmount is number &&
             data.pendingAmount is number &&
             data.userId == request.auth.uid;
    }

    // Entries collection
    match /entries/{entryId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                     isValidId(entryId) && 
                     isValidEntry(request.resource.data) &&
                     request.resource.data.id == entryId;

      allow update: if isSignedIn() && 
                     resource.data.userId == request.auth.uid &&
                     isValidEntry(request.resource.data) &&
                     request.resource.data.userId == resource.data.userId;

      allow delete: if isSignedIn() && 
                     resource.data.userId == request.auth.uid;
    }
  }
}
