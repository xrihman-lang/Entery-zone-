{
  "entities": {
    "Entry": {
      "title": "Daybook Entry",
      "description": "A single transaction entry in the daily daybook",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "customerName": { "type": "string" },
        "type": { "type": "string", "enum": ["S", "O", "V", "K", "D", "SU", "OM"] },
        "totalAmount": { "type": "number" },
        "receivedAmount": { "type": "number" },
        "pendingAmount": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "customerName", "type", "totalAmount", "userId"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A generated bill/invoice for a customer",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "customerName": { "type": "string" },
        "invoiceDate": { "type": "string", "format": "date" },
        "billNo": { "type": "string" },
        "subtotal": { "type": "number" },
        "cgst": { "type": "number" },
        "sgst": { "type": "number" },
        "totalTax": { "type": "number" },
        "grandTotal": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "customerName", "invoiceDate"]
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "A customer support ticket",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "name": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "message"]
    }
  },
  "firestore": {
    "/entries/{entryId}": {
      "schema": "Entry",
      "description": "Collection of all daybook entries across all users"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Collection of generated bills/invoices"
    },
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Customer support requests"
    }
  }
}
